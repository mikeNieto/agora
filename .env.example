# Optional. Master key used to encrypt provider settings on the server.
# If omitted, Agora generates a local key file in the storage directory.
AGORA_PROVIDER_SETTINGS_KEY=

# Optional. Directory where Agora stores encrypted provider settings.
# Local default: ./.agora
# Docker default: /app/data/.agora
AGORA_STORAGE_DIR=

# Optional. Fallback OpenRouter API key used when there is no key saved in Settings.
OPENROUTER_API_KEY=

# Optional. Fallback DeepSeek API key used when there is no key saved in Settings.
DEEPSEEK_API_KEY=

# Optional. Path to the Copilot CLI binary if it is not discoverable automatically.
COPILOT_CLI_PATH=

# Optional. App port. Local dev usually uses 3000. Docker uses 7575.
PORT=